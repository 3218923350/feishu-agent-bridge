{
  "name": "feishu-agent-bridge",
  "version": "0.1.0",
  "description": "Feishu/Lark bridge for Claude Code and Codex with sessions, cards, workspaces, media, and document comments.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "feishu-agent-bridge": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts start",
    "lint": "tsc --noEmit",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "feishu",
    "lark",
    "claude-code",
    "codex",
    "agent",
    "bridge"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "commander": "^14.0.3"
  },
  "overrides": {
    "axios": "^1.18.1",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
